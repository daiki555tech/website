  height:100%;
  object-fit:cover;
}

/* GLASS */
.glass{
  background:rgba(131, 131, 131, 0.08);
  backdrop-filter:blur(15px);
  border-radius:20px;
  margin:15px;
  padding:20px;
}

.title{
