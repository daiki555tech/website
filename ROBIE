.skills div{
  width:50%;
}

/* RIPPLE */
.ripple{
  position:relative;
  overflow:hidden;
  cursor:pointer;
}

.ripple span{
  position:absolute;
  border-radius:50%;
  transform:scale(0);
  background:rgba(83, 55, 55, 0.4);
  animation:rippleEffect 0.6s linear;
  pointer-events:none;
}
</style>
