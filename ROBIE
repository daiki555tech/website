<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Tahoma',Verdana;
}

html{
  scroll-behavior:smooth;
}

body{
  color:white;
  overflow-x:hidden;
  background: linear-gradient(270deg, #1f1f1f, #3a3a3a, #3d5f6d, #0f2027);
  background-size: 800% 800%;
  animation: gradientMove 10s ease infinite;
  position:relative;
}


body::before,
body::after{
  content:"";
  position:absolute;
  width:300px;
  height:300px;
  border-radius:50%;
  filter:blur(80px);
  opacity:0.5;
}

body::before{
  background:#6d2c2e;
  top:10%;
  left:10%;
  animation:blobMove 12s infinite alternate;
}

body::after{
  background:rgb(161, 207, 245);
  bottom:10%;
  right:10%;
  animation:blobMove 10s infinite alternate;
}

@keyframes gradientMove{
  0%{background-position:0% 50%;}
  50%{background-position:100% 50%;}
  100%{background-position:0% 50%;}
}

@keyframes blobMove{
  0%{transform:translate(0,0);}
  100%{transform:translate(50px,-50px);}
}

@keyframes rippleEffect{
  to{
    transform:scale(4);
    opacity:0;
  }
}

/* NAV */
.nav{
  display:flex;
  justify-content:center;
  gap:20px;
  padding:15px;
  backdrop-filter:blur(10px);
  background:rgba(131, 128, 128, 0.05);
  position:sticky;
